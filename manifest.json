{
  "manifest_version": 3,
  "name": "TabTuner",
  "version": "1.0.0",
  "description": "Control audio volume per tab individually with a global mixer.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TabTuner Mixer"
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "volume-up": {
      "suggested_key": {
        "default": "Alt+Shift+Up",
        "mac": "Alt+Shift+Up"
      },
      "description": "Aumentar volume da aba atual"
    },
    "volume-down": {
      "suggested_key": {
        "default": "Alt+Shift+Down",
        "mac": "Alt+Shift+Down"
      },
      "description": "Abaixar volume da aba atual"
    }
  }
}
